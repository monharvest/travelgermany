---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { formatDate } from '../lib/content';

interface Props {
  href: string;
  title: string;
  excerpt: string;
  date: string;
  image?: string;
  category?: string;
  spanClass?: string;
}

const {
  href,
  title,
  excerpt,
  date,
  image = '',
  category = 'Travel Story',
  spanClass = 'span-4',
} = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/uploads/**/*.{jpeg,jpg,png,webp,gif}',
  { eager: true }
);

const localImage = image
  ? allImages[image.replace('/wp-content/uploads/', '/src/assets/uploads/')]?.default
  : null;
---

<article class={`card ${spanClass}`}>
  {localImage ? (
    <Image class="media" src={localImage} alt={title} width={960} height={600} loading="lazy" format="webp" quality={80} />
  ) : image ? (
    <img class="media" src={image} alt={title} width="960" height="600" loading="lazy" decoding="async" />
  ) : null}
  <div class="card-content">
    <p class="kicker">{category}</p>
    <h3><a href={href}>{title}</a></h3>
    <p>{excerpt}</p>
    <div class="card-meta">
      <span>{formatDate(date)}</span>
      <a href={href}>Read story</a>
    </div>
  </div>
</article>

---
// Contact form component with EmailJS integration
---

<form id="contactForm" class="contact-form">
  <div class="form-group">
    <label for="name">Name</label>
    <input type="text" id="name" name="user_name" required aria-required="true" />
  </div>

  <div class="form-group">
    <label for="email">Email</label>
    <input type="email" id="email" name="user_email" required aria-required="true" />
  </div>

  <div class="form-group">
    <label for="subject">Subject</label>
    <input type="text" id="subject" name="subject" required aria-required="true" />
  </div>

  <div class="form-group">
    <label for="message">Message</label>
    <textarea id="message" name="message" rows="6" required aria-required="true"></textarea>
  </div>

  <button type="submit" class="btn-submit" id="submitBtn">Send Message</button>
  <div id="statusMessage" class="status-message"></div>
</form>

<style>
  .contact-form {
    max-width: 600px;
    margin: 2rem auto;
    padding: 2rem;
    background: #f9f9f9;
    border-radius: 8px;
  }

  .form-group {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .form-group label {
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: #333;
    font-size: 0.95rem;
  }

  .form-group input,
  .form-group textarea {
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #4a90e2;
    box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.1);
  }

  .btn-submit {
    background: #4a90e2;
    color: white;
    padding: 0.75rem 2rem;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s ease;
    width: 100%;
  }

  .btn-submit:hover:not(:disabled) {
    background: #357abd;
  }

  .btn-submit:disabled {
    background: #ccc;
    cursor: not-allowed;
  }

  .btn-submit:active:not(:disabled) {
    transform: scale(0.98);
  }

  .status-message {
    margin-top: 1rem;
    padding: 1rem;
    border-radius: 4px;
    text-align: center;
    font-weight: 500;
    display: none;
  }

  .status-message.show {
    display: block;
  }

  .status-message.success {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
  }

  .status-message.error {
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }
</style>

<script>
  type EmailJsResponse = { status: number };
  type EmailJsApi = {
    init: (publicKey: string) => void;
    send: (
      serviceId: string,
      templateId: string,
      params: Record<string, string>,
      publicKey: string
    ) => Promise<EmailJsResponse>;
  };

  // NOTE: Replace with your EmailJS values from emailjs.com
  const EMAILJS_SERVICE_ID = 'service_travelgermany';
  const EMAILJS_TEMPLATE_ID = 'template_contact';
  const EMAILJS_PUBLIC_KEY = 'YOUR_PUBLIC_KEY_HERE';
  const RECIPIENT_EMAIL = 'travelgermany@ulzi.me';

  let emailjsApi: EmailJsApi | undefined;

  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const statusMessage = document.getElementById('statusMessage') as HTMLDivElement | null;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;

  const setStatus = (text: string, kind: 'success' | 'error') => {
    if (!statusMessage) return;
    statusMessage.textContent = text;
    statusMessage.classList.add('show', kind);
  };

  const setLoading = (loading: boolean) => {
    if (!submitBtn) return;
    submitBtn.disabled = loading;
    submitBtn.textContent = loading ? 'Sending...' : 'Send Message';
  };

  const script = document.createElement('script');
  script.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/index.min.js';
  script.onload = () => {
    emailjsApi = (window as Window & { emailjs?: EmailJsApi }).emailjs;
    if (emailjsApi && EMAILJS_PUBLIC_KEY !== 'YOUR_PUBLIC_KEY_HERE') {
      emailjsApi.init(EMAILJS_PUBLIC_KEY);
    }
  };
  document.head.appendChild(script);

  if (form && statusMessage && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!emailjsApi || EMAILJS_PUBLIC_KEY === 'YOUR_PUBLIC_KEY_HERE') {
        setStatus('Email service is not configured yet.', 'error');
        return;
      }

      setLoading(true);
      statusMessage.classList.remove('show', 'success', 'error');

      try {
        const formData = new FormData(form);
        const templateParams = {
          to_email: RECIPIENT_EMAIL,
          from_name: String(formData.get('user_name') ?? ''),
          from_email: String(formData.get('user_email') ?? ''),
          subject: String(formData.get('subject') ?? ''),
          message: String(formData.get('message') ?? ''),
          reply_to: String(formData.get('user_email') ?? ''),
        };

        const response = await emailjsApi.send(
          EMAILJS_SERVICE_ID,
          EMAILJS_TEMPLATE_ID,
          templateParams,
          EMAILJS_PUBLIC_KEY
        );

        if (response.status === 200) {
          setStatus('Message sent successfully. We will get back to you soon.', 'success');
          form.reset();
        } else {
          setStatus('Failed to send message. Please try again.', 'error');
        }
      } catch (error) {
        console.error('EmailJS error:', error);
        setStatus('Failed to send message. Please try again.', 'error');
      } finally {
        setLoading(false);
      }
    });
  }
</script>


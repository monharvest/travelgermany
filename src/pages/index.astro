---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import site from '../data/site.json';
import { excerptFromContent, firstImageFromContent } from '../lib/content';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('posts')).sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/uploads/**/*.{jpeg,jpg,png,webp,gif}',
  { eager: true }
);
const featured = posts[0];
const leadImagePath = featured?.data.featuredImage || (featured ? firstImageFromContent(featured.body ?? '') : '');
const leadImageModule = leadImagePath
  ? allImages[leadImagePath.replace('/wp-content/uploads/', '/src/assets/uploads/')]?.default
  : null;
const latest = posts.slice(0, 6);
const uniqueCategories = [...new Set(posts.flatMap((post) => post.data.categories))].slice(0, 8);
---

<SiteLayout title={`${site.title} | Hidden Germany`} description={site.description}>
  <SiteHeader />
  <main>
    <section class="hero container">
      <div class="hero-card">
        <div class="hero-copy">
          <p class="kicker">Editorial travel journal</p>
          <h1>Germany beyond guidebooks.</h1>
          <p>Small towns, spa villages, and places guidebooks skip — Germany beyond the postcards.</p>
          <div class="hero-actions">
            <a class="btn primary" href="/stories">Read stories</a>
            <a class="btn" href="/about-us">About us</a>
          </div>
        </div>
        <div class="hero-image">
          {leadImageModule ? (
            <Image src={leadImageModule} alt="" width={1400} height={900} widths={[400, 600, 800, 1100, 1400]} sizes="(max-width: 900px) 92vw, 531px" format="webp" quality={80} loading="eager" fetchpriority="high" decoding="sync" class="hero-image-img" />
          ) : leadImagePath ? (
            <img src={leadImagePath} alt="" width="1400" height="900" loading="eager" fetchpriority="high" decoding="sync" class="hero-image-img" />
          ) : null}
        </div>
      </div>
    </section>

    <section class="section container">
      <div class="section-head">
        <h2>Latest Destinations</h2>
        <a class="muted" href="/stories">See all</a>
      </div>
      <div class="grid posts-grid">
        {latest.map((post) => (
          <PostCard href={`/stories/${post.data.slug}`} title={post.data.title} excerpt={post.data.excerpt || excerptFromContent(post.body ?? '')} date={post.data.date} image={post.data.featuredImage || firstImageFromContent(post.body ?? '')} category={post.data.categories[0] || 'Travel Story'} />
        ))}
      </div>
    </section>

    <section class="section container">
      <div class="section-head"><h2>Explore by Theme</h2></div>
      <div class="hero-actions">
        {uniqueCategories.map((category) => <span class="btn">{category}</span>)}
      </div>
    </section>
  </main>
  <SiteFooter />
</SiteLayout>

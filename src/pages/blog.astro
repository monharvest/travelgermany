---
import { getCollection } from 'astro:content';
import SiteLayout from '../layouts/SiteLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PostCard from '../components/PostCard.astro';

const articles = (await getCollection('blog')).sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
const articleSlugs = articles.map((article) => article.data.slug);
---

<SiteLayout title="Blog | Travel Germany" description="Practical travel notes and hidden places across Germany.">
  <SiteHeader />
  <main class="page-shell">
    <section class="container">
      <div class="section-head"><h1>Blog</h1></div>
      <div class="grid posts-grid">
        {articles.map((article, index) => (
          <PostCard href={`/blog/${article.data.slug}/`} title={article.data.title} excerpt={article.data.excerpt} date={article.data.date} image={article.data.featuredImage} category="Blog" spanClass={index % 3 === 0 ? 'span-6' : 'span-4'} />
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</SiteLayout>

<script define:vars={{ articleSlugs }}>
  const legacySlug = new URLSearchParams(window.location.search).get('post');
  if (legacySlug && articleSlugs.includes(legacySlug)) {
    window.location.replace(`/blog/${legacySlug}/`);
  }
</script>

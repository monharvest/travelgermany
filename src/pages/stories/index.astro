---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PostCard from '../../components/PostCard.astro';
import { excerptFromContent, firstImageFromContent } from '../../lib/content';

const posts = (await getCollection('posts')).sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
---

<SiteLayout title="Stories | Travel Germany" description="Travel stories from towns, cities, and regions across Germany.">
  <SiteHeader />
  <main class="page-shell">
    <section class="container">
      <div class="section-head"><h1>Stories</h1></div>
      <div class="grid posts-grid">
        {posts.map((post, index) => (
          <PostCard href={`/stories/${post.data.slug}`} title={post.data.title} excerpt={post.data.excerpt || excerptFromContent(post.body ?? '')} date={post.data.date} image={post.data.featuredImage || firstImageFromContent(post.body ?? '')} category={post.data.categories[0] || 'Travel Story'} spanClass={index % 3 === 0 ? 'span-6' : 'span-4'} />
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</SiteLayout>
